# ============================================================
# Navaja — variables de entorno (plantilla)
# Copia este archivo a `.env.local` y rellena los valores.
# `.env*` está en .gitignore: los secretos NUNCA se versionan.
# Validado en arranque por src/lib/security/env.ts (Zod).
# ============================================================

# ----- Multi-tenant --------------------------------------------

# Dominio raíz del SaaS. Los tenants viven en `{slug}.$ROOT` y los dominios
# propios se resuelven contra la tabla `domains`. En dev no hace falta:
# el proxy también acepta {slug}.localhost:3000 y {slug}.lvh.me:3000.
NEXT_PUBLIC_ROOT_DOMAIN=navaja.app

# ----- Supabase (al conectar el backend real) -----------------

# URL pública del proyecto. Segura para el cliente.
NEXT_PUBLIC_SUPABASE_URL=

# Llave anónima: pública por diseño, su poder lo limita RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Llave service_role: ⚠️ SECRETA. Solo en el servidor.
# NUNCA le pongas el prefijo NEXT_PUBLIC_ (la expondría al navegador).
# Salta TODA la seguridad RLS — trátala como una contraseña maestra.
# La usan las Server Actions del dashboard (tras verificar la membresía del
# usuario en lib/auth.ts) y el alta de cuentas (auth.admin.createUser).
# El público solo reserva vía la RPC con la anon.
SUPABASE_SERVICE_ROLE_KEY=

# ----- Mercado Pago (anticipos de reserva — PAGOS.md Track A) --

# Credenciales de la APLICACIÓN de Navaja en el panel de developers de MP
# (https://www.mercadopago.com.mx/developers). ⚠️ SECRETAS (salvo el client id).
# Los tokens de cada barbería NO van aquí: viven cifrados en `payment_accounts`.
MP_CLIENT_ID=
MP_CLIENT_SECRET=

# Firma de los webhooks de MP (x-signature). Se genera en el panel al
# registrar la URL de notificaciones.
MP_WEBHOOK_SECRET=

# Llave AES-256-GCM para cifrar los tokens MP en reposo: 32 bytes en hex
# (64 caracteres). Genera una con:  openssl rand -hex 32
PAYMENTS_ENCRYPTION_KEY=
