# ============================================================
# Navaja — variables de entorno (plantilla)
# Copia este archivo a `.env.local` y rellena los valores.
# `.env*` está en .gitignore: los secretos NUNCA se versionan.
# Validado en arranque por src/lib/security/env.ts (Zod).
# ============================================================

# ----- Supabase (al conectar el backend real) -----------------

# URL pública del proyecto. Segura para el cliente.
NEXT_PUBLIC_SUPABASE_URL=

# Llave anónima: pública por diseño, su poder lo limita RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Llave service_role: ⚠️ SECRETA. Solo en el servidor.
# NUNCA le pongas el prefijo NEXT_PUBLIC_ (la expondría al navegador).
# Salta TODA la seguridad RLS — trátala como una contraseña maestra.
SUPABASE_SERVICE_ROLE_KEY=
